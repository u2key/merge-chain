# Nginx リバースプロキシ設定例
# レンタルサーバーで merge-chain を動かす場合の設定
# 
# 使い方:
# 1. このファイルを参考に /etc/nginx/sites-available/merge-chain を作成
# 2. ln -s /etc/nginx/sites-available/merge-chain /etc/nginx/sites-enabled/merge-chain
# 3. sudo nginx -t && sudo systemctl reload nginx

upstream merge_chain {
  # pm2 が起動しているポート（デフォルト 3000）
  server localhost:3000;
  # 複数インスタンスの場合: server localhost:3001; など
}

server {
  listen 80;
  server_name your-domain.com;  # 自分のドメインに置き換え
  
  # 最大アップロードサイズ
  client_max_body_size 50M;

  location / {
    proxy_pass http://merge_chain;
    proxy_http_version 1.1;
    
    # 重要: Socket.io の WebSocket を正しく通す
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    
    # リバースプロキシ必須ヘッダ
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    
    # タイムアウト設定（WebSocket 用に長めに）
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;
    
    # バッファリング無効化（リアルタイム通信）
    proxy_buffering off;
  }

  # Socket.io 用ポーリングフォールバック
  location /socket.io {
    proxy_pass http://merge_chain/socket.io;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_buffering off;
  }
}
